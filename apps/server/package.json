{
  "name": "@apix/server",
  "version": "0.0.0",
  "private": true,
  "description": "Apix API server (Fastify + TypeScript)",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@apix/shared": "workspace:*",
    "@fastify/cookie": "^9.3.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/multipart": "^8.1.0",
    "bcrypt": "^5.1.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.36.0",
    "exceljs": "^4.4.0",
    "fastify": "^4.26.0",
    "jsonwebtoken": "^9.0.0",
    "minio": "^7.1.0",
    "node-cron": "^3.0.0",
    "pg": "^8.11.0",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "3.23.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/exceljs": "^1.3.2",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.0",
    "@types/pg": "^8.10.0",
    "drizzle-kit": "^0.22.0",
    "rimraf": "^5.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}