# =============================================================================
# Apix (Slot Manager) — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://apix:apix_password@localhost:5432/apix

# --- JWT Secrets ---
# Generate with: openssl rand -hex 64
JWT_SECRET=change-me-to-a-random-secret
JWT_REFRESH_SECRET=change-me-to-another-random-secret

# --- MinIO (S3-compatible storage for photos) ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=apix-photos
MINIO_USE_SSL=false

# --- Server ---
SERVER_PORT=3001
SERVER_HOST=0.0.0.0
NODE_ENV=development

# --- Client ---
VITE_API_URL=http://localhost:80/api